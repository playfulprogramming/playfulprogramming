---
import Barebones from "#src/layouts/barebones.astro";

import "../../../views/collections/framework-field-guide/fonts/plus-jakarta-sans.css";
import "../../../views/collections/framework-field-guide/fonts/changa-one.css";
import "../../../views/collections/framework-field-guide/tokens/adventure.scss";
import "../../../views/collections/framework-field-guide/tokens/buttons.scss";
import "../../../views/collections/framework-field-guide/tokens/colors.scss";
import "../../../views/collections/framework-field-guide/tokens/book-sections.scss";
import "../../../views/collections/framework-field-guide/tokens/dimensions.scss";
import "../../../views/collections/framework-field-guide/tokens/text-styles.scss";
import "../../../views/collections/framework-field-guide/tokens/themes.scss";
import "../../../views/collections/framework-field-guide/styles/global-ffg.css";
import "../../../views/collections/framework-field-guide/styles/buttons.css";
import "../../../views/collections/framework-field-guide/styles/focus.css";
import "../../../views/collections/framework-field-guide/styles/svg-layers.css";
import "../../../views/collections/framework-field-guide/tokens/forms.scss";
import "../../../views/collections/framework-field-guide/tokens/sign-up.scss";

import SEO from "#src/components/seo/seo.astro";
import Header from "#src/views/collections/framework-field-guide/segments/header.astro";
import Hero from "../../../views/collections/framework-field-guide-fundamentals/segments/hero-fundamentals.astro";
import Fundamentals from "../../../views/collections/framework-field-guide-fundamentals/segments/fundamentals-fundamentals.astro";
import Ecosystem from "../../../views/collections/framework-field-guide-fundamentals/segments/ecosystem-fundamentals.astro";
import { getCollectionBySlug, getPersonById } from "../../../utils/api";

const collection = getCollectionBySlug(
	"framework-field-guide-fundamentals",
	"en",
)!;
---

<Barebones>
	<SEO
		slot="head"
		title={collection.title}
		description={collection.description}
		peopleData={[getPersonById("crutchcorn", "en")!]}
		publishedTime={collection.published}
		type={"book"}
		shareImage={collection.socialImgMeta?.relativeServerPath}
	/>
	<Header />
	<main>
		<Hero />
		<Fundamentals />
		<Ecosystem />
	</main>
</Barebones>
<script>
	import { enableSmoothScrollForAnchorsToCurrentPage } from "#utils/smooth-scroll-for-anchors-to-current-page";
	enableSmoothScrollForAnchorsToCurrentPage();
</script>
<script>
	import { enableColorChangeListeners } from "../../../views/collections/framework-field-guide/scripts/color-change-listener";
	enableColorChangeListeners();
</script>
<script>
	import { enableParallaxScrolling } from "../../../views/collections/framework-field-guide/scripts/parallax-scrolling";
	enableParallaxScrolling();
</script>
