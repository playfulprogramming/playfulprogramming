---
import Barebones from "src/layouts/barebones.astro";
import "../../../views/collections/framework-field-guide/fonts/fira-code.css";
import "../../../views/collections/framework-field-guide/fonts/plus-jakarta-sans.css";
import "../../../views/collections/framework-field-guide/fonts/changa-one.css";
import "../../../views/collections/framework-field-guide/fonts/playpen-sans.css";
import "../../../views/collections/framework-field-guide/tokens/dimensions.scss";
import "../../../views/collections/framework-field-guide/tokens/colors.scss";
import "../../../views/collections/framework-field-guide/tokens/text-styles.scss";
import "../../../views/collections/framework-field-guide/tokens/themes.scss";
import "../../../views/collections/framework-field-guide/tokens/adventure.scss";
import "../../../views/collections/framework-field-guide/tokens/buttons.scss";
import "../../../views/collections/framework-field-guide/tokens/code-block.scss";
import "../../../views/collections/framework-field-guide/tokens/book-sections.scss";
import "../../../views/collections/framework-field-guide/tokens/transition-timer.scss";
import "../../../views/collections/framework-field-guide/tokens/quotes.scss";
import "../../../views/collections/framework-field-guide/tokens/sign-up.scss";
import "../../../views/collections/framework-field-guide/tokens/forms.scss";
import "../../../views/collections/framework-field-guide/styles/global-ffg.css";
import "../../../views/collections/framework-field-guide/styles/buttons.css";
import "../../../views/collections/framework-field-guide/styles/focus.css";
import "../../../views/collections/framework-field-guide/styles/svg-layers.css";
import "../../../views/collections/framework-field-guide/styles/shiki.scss";
import SEO from "src/components/seo/seo.astro";
import Header from "src/views/collections/framework-field-guide/segments/header.astro";
import Hero from "src/views/collections/framework-field-guide/segments/hero.astro";
import Fundamentals from "src/views/collections/framework-field-guide/segments/fundamentals.astro";
import Ecosystem from "src/views/collections/framework-field-guide/segments/ecosystem.astro";
import Internals from "src/views/collections/framework-field-guide/segments/internals.astro";
import Quotes from "src/views/collections/framework-field-guide/segments/quotes.astro";
import AdventureContinues from "src/views/collections/framework-field-guide/segments/adventure-continues.astro";
import YourGuide from "src/views/collections/framework-field-guide/segments/your-guide.astro";
import CodeBlock from "src/views/collections/framework-field-guide/segments/code-block.astro";
import TheRestContainer from "src/views/collections/framework-field-guide/segments/the-rest-container.astro";
import SignUp from "src/views/collections/framework-field-guide/segments/sign-up.astro";
import WhyLearnAllThree from "src/views/collections/framework-field-guide/segments/why-learn-all-three.astro";
import WhatDoIGet from "src/views/collections/framework-field-guide/segments/what-do-i-get.astro";
import { getCollectionBySlug, getPersonById } from "utils/api";
import BlockingTabsSignalScript from "components/tabs/blocking-tabs-signal-script.astro";

const collection = getCollectionBySlug("framework-field-guide", "en")!;
---

<Barebones>
	<SEO
		slot="head"
		title={collection.title}
		description={collection.description}
		peopleData={[getPersonById("crutchcorn", "en")!]}
		publishedTime={collection.published}
		type={"book"}
		shareImage={collection.socialImgMeta?.relativeServerPath}
	/>
	<Header />
	<main>
		<Hero />
		<Fundamentals />
		<Ecosystem />
		<Internals />
		<TheRestContainer>
			<WhyLearnAllThree />
			<WhatDoIGet />
			<CodeBlock />
			<YourGuide />
			<Quotes />
			<AdventureContinues />
			<SignUp />
		</TheRestContainer>
	</main>
</Barebones>
<script>
	import { enableSmoothScrollForAnchorsToCurrentPage } from "utils/smooth-scroll-for-anchors-to-current-page";
	enableSmoothScrollForAnchorsToCurrentPage();
</script>
<script>
	import { enableColorChangeListeners } from "../../../views/collections/framework-field-guide/scripts/color-change-listener";
	enableColorChangeListeners();
</script>
<script>
	import { enableParallaxScrolling } from "../../../views/collections/framework-field-guide/scripts/parallax-scrolling";
	enableParallaxScrolling();
</script>
<BlockingTabsSignalScript />
