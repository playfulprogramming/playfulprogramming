---
import { PostCardGrid } from "#src/components/post-card/post-card-grid";
import { Button } from "#components/button/button.tsx";
import { Languages, PostInfo, CollectionInfo } from "#types/index.ts";
import { translate } from "#utils/translations.ts";
import { CollectionCard } from "#components/collection-card/collection-card.tsx";
import { SubHeader } from "../../components/subheader/subheader";
import Hero from "../../components/hero/hero.astro";
import SearchSection from "../../components/search-section/search-section.astro";
import styles from "./homepage.module.scss";
import { buildSearchQuery } from "#src/views/search/search";
import * as api from "#utils/api.ts";
import { isDefined } from "#utils/is-defined.ts";

export interface HomepageProps {
	posts: PostInfo[];
	collections: CollectionInfo[];
	locale: Languages;
}

const { posts, collections, locale } = Astro.props as HomepageProps;

const postAuthors = new Map(
	(
		await Promise.all(
			[...new Set(posts.flatMap((p) => p.authors))].map((id) =>
				api.getPersonById(id, locale),
			),
		)
	)
		.filter(isDefined)
		.map((u) => [u.id, u]),
);

const collectionsWithAuthors = await Promise.all(
	collections.map(async (collection) => {
		const collectionAuthors = (
			await Promise.all(
				collection.authors.map((id) =>
					api.getPersonById(id, collection.locale),
				),
			)
		).filter(isDefined);

		return { ...collection, authorsMeta: collectionAuthors };
	}),
);
---

<Hero />
<section>
	<SubHeader tag="h2" text="Recent articles" id="posts-header">
		<Button
			href={`/search?${buildSearchQuery({ searchQuery: "*", display: "articles" })}`}
			aria-labelledby="posts-header"
		>
			{translate(Astro, "action.view_all")}
		</Button>
	</SubHeader>

	<PostCardGrid
		aria-labelledby="posts-header"
		postsToDisplay={posts}
		postAuthors={postAuthors}
		postHeadingTag="h3"
	/>
</section>

<section>
	<SubHeader tag="h2" text="Collections" id="collections-header">
		<Button
			href={`/search?${buildSearchQuery({
				searchQuery: "*",
				display: "collections",
			})}`}
			aria-labelledby="collections-header"
		>
			{translate(Astro, "action.view_all")}
		</Button>
	</SubHeader>

	<ul
		role="list"
		aria-labelledby="collections-header"
		class={styles.collectionsGrid}
	>
		{
			collectionsWithAuthors.map((collection) => (
				<CollectionCard
					collection={collection}
					authors={collection.authorsMeta}
					headingTag="h3"
				/>
			))
		}
	</ul>
</section>

<SearchSection />
